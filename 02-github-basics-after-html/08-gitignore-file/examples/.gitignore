# ============================================
# Frontend Project .gitignore
# ============================================

# ---- OS Files ----
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
desktop.ini

# Linux
*~

# ---- Editor Files ----
# VS Code
.vscode/
*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# Vim
*.swp
*.swo

# Emacs
\#*\#
.#*

# ---- Environment Variables ----
# NEVER commit these — they contain secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ---- Node.js ----
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ---- Build Output ----
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.output/

# ---- Testing ----
coverage/
.nyc_output/
test-results/
playwright-report/

# ---- Caching ----
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/

# ---- Temporary Files ----
*.tmp
*.temp
*.bak
*.orig
